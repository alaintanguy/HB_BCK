<?xml version="1.0" encoding="utf-8"?>

<!--
  HealthBridge activity_main.xml
  Two distinct modes:
    Conversation Mode – map + status + conversation history + Write button
    Compose Mode      – compose editor + Send button (map + history hidden)
-->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ========================= -->
    <!-- MAP (hidden in Compose Mode) -->
    <!-- ========================= -->

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"/>

    <!-- ========================= -->
    <!-- STATUS -->
    <!-- ========================= -->

    <TextView
        android:id="@+id/statusText"
        android:layout_marginTop="0dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#202020"
        android:padding="6dp"
        android:text="🟢 ONLINE    🕒 --:--    🔋 --%"
        android:textAlignment="center"
        android:textColor="#FFFF00"
        android:textSize="12sp"
        android:textStyle="bold"/>

    <!-- ========================= -->
    <!-- CONVERSATION HISTORY      -->
    <!-- Read-only, append-only.   -->
    <!-- Scrollable, hidden in     -->
    <!-- Compose Mode.             -->
    <!-- ========================= -->

    <ScrollView
        android:id="@+id/conversationScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:layout_marginTop="10dp"
        android:fillViewport="false">

        <TextView
            android:id="@+id/messageView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:gravity="top|start"
            android:padding="12dp"
            android:textColor="#000000"
            android:textSize="22sp"/>

    </ScrollView>

    <!-- ========================= -->
    <!-- COMPOSE EDITOR            -->
    <!-- Editable, shown only in   -->
    <!-- Compose Mode.             -->
    <!-- ========================= -->

    <EditText
        android:id="@+id/composeEdit"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#FFFFAA"
        android:textColor="#000000"
        android:minLines="6"
        android:maxLines="6"
        android:gravity="top|start"
        android:padding="12dp"
        android:hint="Type your message here…"
        android:visibility="gone"/>

    <!-- ========================= -->
    <!-- ACTION BUTTONS            -->
    <!-- speakButton: always gone  -->
    <!--   (use Gboard mic instead)-->
    <!-- writeButton: Conversation -->
    <!-- sendButton:  Compose Mode -->
    <!-- ========================= -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="0dp">

        <!-- speakButton kept for SpeechManager wiring; hidden per UI spec -->
        <Button
            android:id="@+id/speakButton"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:text="🎤"
            android:textSize="34sp"
            android:visibility="gone"/>

        <!-- writeButton: visible in Conversation Mode only -->
        <Button
            android:id="@+id/writeButton"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:text="✏️"
            android:textSize="34sp"/>

        <!-- sendButton: visible in Compose Mode only -->
        <Button
            android:id="@+id/sendButton"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:text="📤"
            android:textSize="34sp"
            android:visibility="gone"/>

        <!-- ackButton: reserved, not shown -->
        <Button
            android:id="@+id/ackButton"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone"
            android:text="ACK"/>

    </LinearLayout>

</LinearLayout>